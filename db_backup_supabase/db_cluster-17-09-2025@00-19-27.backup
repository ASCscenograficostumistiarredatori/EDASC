--
-- Data for Name: artists; Type: TABLE DATA; Schema: public; Owner: postgres
--

COPY public.artists (id, first_name, last_name, profile_picture, bio, created_at, url_id, published, searchable, show_in_homepage, url, subtitle, has_subtitle) FROM stdin;
59610c0a-4e0d-4cbb-9e13-fc40909ec028	Anna	Mode	https://zlntcwuxekavvhzqhbxz.supabase.co/storage/v1/object/public/assets/images/Foto%20Artisti/I%20nostri%20artigiani/Annamode/loghetto_anna_mode.jpg	Sartoria attiva dal 1946, che dispone di un magazzino con oltre 200mila costumi, 25mila accessori e un archivio di 18mila autentici e accessori originali dal Settecento ai giorni nostri, per il noleggio o la vendita.	2024-06-10 12:51:32.61178+00	anna-mode	t	t	t	\N	\N	t
715f946b-f3ac-4742-9cb6-7ac54a28ab66	Raffaella	Giovannetti	https://zlntcwuxekavvhzqhbxz.supabase.co/storage/v1/object/public/assets/images/Foto%20Professionisti/Arredatori/Raffaella%20Giovannetti/GIOVANNETTI.jpg.webp	Arredatrice cinematografica, Raffaella Giovannetti ha collaborato con scenografi di fama internazionale come Dante Ferretti, con cui ha dato vita alle ambientazioni di pellicole di grande successo. Assistente di Francesca Lo Schiavo ha partecipato a Gangs of New York di Martin Scorsese. Nel 2013, ha lavorato con Maurizio Sabatini a La migliore offerta.\\n	2024-06-07 12:59:22.321283+00	raffaella-giovannetti	t	t	t	\N	\N	t
9bbfb2ed-8905-434f-b170-ce0c883dc587	Giorgio	Armani	https://zlntcwuxekavvhzqhbxz.supabase.co/storage/v1/object/public/assets/images/Foto%20Artisti/Costumisti/Giorgio%20Armani/ARMANI.jpg.webp	Stilista, fondatore dell'azienda omonima, Giorgio Armani dal 1980 ha disegnato i costumi di scena per diversi attori e attrici, a cominciare da Richard Gere per il film American Gigolò. Nel 1999 ha prodotto il documentario di Martin Scorsese sul cinema italiano Il mio viaggio in Italia. Armani è uno dei brand più amati anche per i red carpet.	2024-06-07 14:04:55.637723+00	\N	t	t	t	\N	\N	t
9d80de96-8938-44ab-9dec-7bb2d12eb741	David	di Donatello	https://zlntcwuxekavvhzqhbxz.supabase.co/storage/v1/object/public/assets/images/Foto%20Professionisti/I%20Premi/David%20di%20Donatello/logo-ocra250.png	n	2024-06-07 14:59:23.411074+00	\N	t	t	t	\N	\N	t
b1549221-c7b3-4c5d-a5f8-9f56bc9fa080	Fondazione	Giorgio Cini	https://zlntcwuxekavvhzqhbxz.supabase.co/storage/v1/object/public/assets/images/Foto%20Artisti/Fondazioni/Tirelli%20Trappetti/TirelliTrappetti.jpeg	n	2024-06-10 12:36:55.512914+00	\N	t	t	t	\N	\N	t
